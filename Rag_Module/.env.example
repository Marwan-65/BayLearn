APP_NAME="RAG-APP"
APP_VERSION="0.1"

# ====================== Model Configurations ======================
GENERATION_BACKEND=GROQ
GROQ_API_KEY= put you key here 
EMBEDDING_BACKEND=LOCAL

GENERATION_MODEL_ID=models/mistral-7b-instruct-v0.1.Q4_K_M.gguf
EMBEDDING_MODEL_ID=BAAI/bge-small-en-v1.5
EMBEDDING_MODEL_SIZE=384

# Max characters allowed in a user question (matches searchRequest.max_length=5000)
INPUT_DEFAULT_MAX_CHARACTERS=5000
# Max tokens the LLM may return per answer (1024 ≈ ~750 words, fits tutor-style answers)
GENERATION_DEFAULT_MAX_TOKENS=1024
GENERATION_DEFAULT_TEMPERATURE=0.1
GENERATION_MODEL_ID=llama-3.1-8b-instant

# ====================== Vector DB Configurations ======================

VECTOR_DB_BACKEND = "QDRANT"
VECTOR_DB_PATH = "qdrant_db"
VECTOR_DB_DISTANCE_METHOD = "cosine"

# ====================== Contextual Compression ======================
COMPRESSION_ENABLED=true
COMPRESSION_SIMILARITY_THRESHOLD=0.3
COMPRESSION_MIN_KEEP_RATIO=0.4
COMPRESSION_MIN_CHUNK_LENGTH=200
COMPRESSION_SKIP_SINGLE_CHUNK=true
COMPRESSION_RETRIEVAL_MULTIPLIER=2

# ====================== Reranker Configurations ======================

RERANKER_ENABLED=False
RERANKER_BACKEND=CROSS_ENCODER
RERANKER_MODEL_ID=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKER_OVER_RETRIEVAL_MULTIPLIER=3

# ====================== Other Module URLs ======================
# Set these when teammate modules are running as separate services
EQUATION_MODULE_URL=http://localhost:9001


# Phase 5: Input Parsing Module URL
# This is your I/P's FastAPI service that parses PDFs, images, audio, video
INPUT_PARSING_MODULE_URL=http://localhost:8100

# ====================== Per-type Upload Size Limits (MB) ======================
# Applied in routes/input_parsing.py based on the file extension.
UPLOAD_MAX_MB_PDF=50
UPLOAD_MAX_MB_IMAGE=20
UPLOAD_MAX_MB_AUDIO=200
UPLOAD_MAX_MB_VIDEO=1024
UPLOAD_MAX_MB_DEFAULT=25

# ====================== Multi-Query (RAG-Fusion) ======================
MULTI_QUERY_ENABLED=True
MULTI_QUERY_COUNT=3

# ====================== Contextual Retrieval (Anthropic 2024) ======================
CONTEXTUAL_RETRIEVAL_ENABLED=True
CONTEXTUAL_RETRIEVAL_MAX_TOKENS=100

# ====================== BM25 + RRF Hybrid Retrieval ======================

BM25_ENABLED=True
BM25_BACKEND=IN_MEMORY
BM25_INDEX_DIR=bm25_db
BM25_K1=1.5
BM25_B=0.75
RRF_K=60
HYBRID_OVER_RETRIEVAL_MULTIPLIER=2
