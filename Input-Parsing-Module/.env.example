# Copy this file to .env and fill in your API keys.
# Only GEMINI_API_KEY is required for Gemini OCR.
# GROQ_API_KEY is optional fallback for scanned/handwritten OCR.

# API keys
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# Model selection
GEMINI_MODEL=gemini-2.5-flash-lite
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# OCR routing and quota controls
OCR_EMBEDDED_IMAGES=true
MAX_OCR_CALLS_PER_DOC=5
GEMINI_MAX_REQUESTS_PER_MINUTE=8
GEMINI_OCR_MAX_WORKERS=1
SCANNED_PAGE_RENDER_ZOOM=1.5

# OCR quality and filtering
OCR_QUALITY_THRESHOLD=0.4
PADDLE_MIN_CONFIDENCE=0.6
PADDLE_MIN_LONG_EDGE_PX=2400
GROQ_MAX_LONG_EDGE_PX=1600

# Table extraction
ENABLE_IMG2TABLE=true

# Image tile stitching
TILE_MAX_SINGLE_DIM_PX=512
TILE_MAX_STRIP_SHORT_DIM_PX=300
TILE_MIN_COUNT=3
TILE_STITCH_GAP_PT=4

# RAG chunk cleanup and dedup
MIN_CHUNK_CHARS=8
TEXT_MERGE_THRESHOLD=60
IMAGE_DEDUP_THRESHOLD=0.7

# Database connection (PostgreSQL)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.xxxxxxxxxxxx.supabase.co:5432/postgres