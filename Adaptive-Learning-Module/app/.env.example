# ─────────────────────────────────────────────────────────────────────────────
# Adaptive-Learning-Module — environment configuration
# Fill in your values and save this file as .env (no .example suffix).
# ─────────────────────────────────────────────────────────────────────────────

# ── Shared (both scripts use this) ───────────────────────────────────────────
# Connection string for the Adaptive-Learning / concepts database
CONCEPT_DB_URL=postgresql://postgres.yzwbtc:example@aws.supabase.com:6543/postgres

# ── eppo_inference.py ─────────────────────────────────────────────────────────
# Integer ID of the student/user whose enrolled courses define the concept pool
EPPO_USER_ID=3

# ── concept_extractor.py ──────────────────────────────────────────────────────
# Connection string for the Input-Parsing-Module chunks database
CHUNK_DB_URL=postgresql://postgres.yzwbtc:example@aws.supabase.com:6543/postgres

# Groq API key  (https://console.groq.com)
GROQ_API_KEY=gsk_exampl

# Source document — fill in exactly ONE of the two:
FILE_ID=4483ec5e-5199-43e1-9e50-421cef7a4ea6
FILE_NAME=

# Course name to create/reuse in the concepts database
COURSE_NAME=Test

ACM_CCS_PATH=./dataset\acm_ccs2012-1626988337597.xml


# ── Question Generation Module ────────────────────────────────────────────────
# Base URL of the FastAPI question generation service
QUESTION_GEN_BASE_URL=http://localhost:8001

# Optional overrides (leave blank to use defaults shown)
# GROQ_MODEL=llama-3.3-70b-versatile
# MAX_CHARS=120000
# DRY_RUN=false
