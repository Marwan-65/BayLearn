# Required: Gemini API key for LLM classification/extraction
GEMINI_API_KEY=your_gemini_api_key_here

# LLM model and token windowing
LLM_MODEL=gemini-2.5-flash
LLM_MAX_SINGLE_TOKENS=24000

# Bridge endpoint to Input Parsing Module upload API
INPUT_PARSING_UPLOAD_URL=http://localhost:8000/upload

# Viewer base URLs used by /v1/launch
LINKED_LIST_VIEWER_URL=http://localhost:8081
SCHEDULER_VIEWER_URL=http://localhost:8082

# Optional values used by script mode in llm_orchestrator.py
# LLM_PAYLOAD_PATH=llm_payload1.json
# LLM_OUT_DIR=outputs
# LLM_SCHEDULER_TXT=../Scheduler Animation/scheduler/processes.txt
